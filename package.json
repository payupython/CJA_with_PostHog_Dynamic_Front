{
  "name": "avisador-entradas",
  "version": "0.1.0",
  "description": "Ticket availability notifier",
  "type": "module",
  "scripts": {
    "migrate": "tsx src/db/migrate.ts",
    "api": "tsx watch src/api/index.ts",
    "rules": "tsx watch src/rules-engine/engine.ts",
    "frontend": "cd src/frontend && npm run dev",
    "dev": "concurrently \"npm run api\" \"npm run rules\" \"npm run frontend\"",
    "scan": "tsx src/full-scan.ts",
    "scan:dashboard": "tsx src/scan-dashboard.ts",
    "scan:canal": "tsx src/scan-teatro-canal.ts",
    "scan:zarzuela": "tsx src/scan-zarzuela.ts",
    "scan:real": "tsx src/scan-teatro-real.ts",
    "scan:nacional": "tsx src/scan-auditorio-nacional.ts",
    "server": "tsx src/api/index.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/nodemailer": "^8.0.0",
    "better-sqlite3": "^9.6.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.7",
    "playwright": "^1.59.1",
    "redis": "^5.12.1",
    "resend": "^4.0.2",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "url-parse": "^1.5.10"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0"
  }
}
