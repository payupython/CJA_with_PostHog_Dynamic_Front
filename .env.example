# Application
NODE_ENV=development
PORT=3002

# Database
DB_PATH=./data/avisador.db

# Security - CORS
# In dev: defaults to '*'. In production: set to your frontend domain.
# Tunnel URLs (*.trycloudflare.com) are always allowed automatically.
CORS_ORIGIN=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_REQUESTS=100

# Scraping
SCRAPER_TIMEOUT=30000
SCRAPER_MIN_DELAY_MS=25
SCRAPER_MAX_DELAY_MS=45
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Gmail SMTP (required for magic link emails)
# Generate an App Password at https://myaccount.google.com/apppasswords
GMAIL_USER=tu@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# App URL for magic links in emails
# - In dev: defaults to http://localhost:5173
# - With tunnels: run-tunnels.sh writes .tunnel-frontend-url automatically
# - Set explicitly to a non-localhost URL to skip tunnel auto-detection
APP_URL=http://localhost:5173
