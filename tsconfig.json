{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@db": ["./src/db/index.ts"],
      "@db/*": ["./src/db/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
